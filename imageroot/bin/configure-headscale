import os
import secrets
import string
import agent

def generate_secret(length=32):
    """Generate a random secret string"""
    alphabet = string.ascii_letters + string.digits
    return ''.join(secrets.choice(alphabet) for _ in range(length))

def substitute_env_vars(content, env_vars):
    """Replace ${VAR} patterns with environment variable values"""
    for key, value in env_vars.items():
        content = content.replace(f'${{{key}}}', str(value))
    return content

# Read smarthost settings if available
smarthost_env = agent.read_envfile("smarthost.env")
env_vars.update(smarthost_env)

# Template directory
template_dir = '../templates'

# Process Headscale configuration
if not os.path.exists("config.yaml"):
	with open(f'{template_dir}/config.yaml', 'r') as sf:
        with open('config.yaml', 'w') as df:
            df.write(sf.read())

# Process Headplane configuration
with open(f'{template_dir}/config-headplane.yaml', 'r') as f:
    config-headplane = substitute_env_vars(f.read(), env_vars)

with open('config-headplane.yaml', 'w') as f:
    f.write(config-headplane)
